{
    "url": "http://localhost",
    "start": "/",
    "gateway": {
        "port": 10000,
        "baseUrl": "http://localhost:10000"
    },
    "requests": {
        "user":{
            "exist": "user.exist",
            "name":{
                "exits": "user.name.exists",
                "valdate": "user.name.validate",
                "tell": "user.name.tell"
            }
        },
        "catalog":{
            "product": {
                "exist": "catalog.product.exist"
            }
        }
    },
    "events": {
        "user":{
            "register": "user.create",
            "added": "user.added",
            "not.register": "user.re.register"
        },
        "review": {
            "created": "review.created"
        }
    },
    "ports":{
        "back":{
            "requestBus": 10002,
            "eventBus":10001,
            "gateway": 10000,
            "images": 3000,
            "auth": 3001,
            "user": 3002,
            "catalog": 3003,
            "review": 3004,
            "history": 3005
        },
        "front":{
            "shell": 4000,
            "auth": 4001,
            "user": 4002,
            "catalog": 4003,
            "review": 4004,
            "history": 4005
        }
        
    },
    "paths":{
        "start": "/",
        "requests":{
            "request": "/requisicao"
        },
        "gateway":{
            "request": "/requisicao"
        },
        "events":{
            "event": "/eventos",
            "subscribe": "/inscricao",
            "unsubscribe": "/desinscricao" 
        },
        "auth":{
                "login": "/login",
                "register": "/cadastro",
                "update": {
                    "password": "/perfil/atualizar/senha"  
                } 
            },
        "user":{
                "perfil": "/perfil",
                "update": "/perfil/atualizar"
            },
        "catalog":{
                "catalog": "/catalogo",
                "product": "/produto"    
            },
        "history":{
            "history": "/historico"
        },
        "search":{
                "search": "/comparar"
            },
        "review": {
            "list": "/reviews/produto",
            "create": "/reviews"
        }
    },
    "services":{
        "auth":{
            "port": 10000,
            "endpoints":{
                "login": "/login",
                "register": "/cadastro"
            }
        },
        "user":{
            "port": 10000,
            "endpoints":{
                "perfil": "/perfil",
                "update": "/perfil/atualizar"
            }
        },
        "catalog":{
            "port": 10000,
            "endpoints":{
                "catalog": "/catalogo",
                "product": "/produto"
            }
        },
        "search":{
            "port": 10000,
            "endpoints":{
                "search": "/comparar"
            }
        },
        "review": {
            "port": 10000,
            "endpoints": {
                "list": "/reviews/produto",
                "create": "/reviews"
            }
        }
    }
}