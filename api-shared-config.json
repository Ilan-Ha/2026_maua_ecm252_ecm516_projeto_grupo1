{
    "url": "http://localhost",
    "start": "/",
    "gateway": {
        "port": 10000,
        "baseUrl": "http://localhost:10000"
    },
    "services": {
        "auth": {
            "port": 10000,
            "endpoints": {
                "login": "/login",
                "register": "/cadastro"
            }
        },
        "user": {
            "port": 10000,
            "endpoints": {
                "perfil": "/perfil",
                "update": "/perfil/atualizar"
            }
        },
        "catalog": {
            "port": 10000,
            "endpoints": {
                "catalog": "/catalogo",
                "produto": "/produto"
            }
        },
        "search": {
            "port": 10000,
            "endpoints": {
                "search": "/comparar"
            }
        },
        "review": {
            "port": 10000,
            "endpoints": {
                "list": "/reviews/produto",
                "create": "/reviews"
            }
        },
        "history": {
            "port": 3000,
            "endpoints": {
                "history": "/historico"
            }
        }
    }
}
