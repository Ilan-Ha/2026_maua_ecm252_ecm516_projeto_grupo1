{
    "url": "http://localhost",
    "start": "/",
    "services":{
        "auth":{
            "port":3000,
            "endpoints":{
                "login": "/login",
                "register": "/cadastro"
            }
        },
        "user":{
            "port":3000,
            "endpoints":{
                "perfil": "/perfil",
                "update": "/perfil/atualizar"
            }
        },
        "catalog":{
            "port":3000,
            "endpoints":{
                "catalog": "/catalogo",
                "produto": "/produto"
            }
        },
        "search":{
            "port":3000,
            "endpoints":{
                "search": "/comparar"
            }
        },
        "review": {
            "port": 10000,
            "endpoints": {
                "list": "/reviews/produto",
                "create": "/reviews"
            }
        }
    }
}